# Скопируй в stylist-ai.env. По умолчанию — как у агента hermes: OpenRouter.
#
# AI_PROVIDER = openrouter | openai | anthropic
#   openrouter → anthropic/claude-opus-4.8  (OPENROUTER_API_KEY — тот же ключ, что у hermes,
#                                             лежит в cyprus.env/hermes.env, с балансом) ← как hermes
#   openai     → gpt-4.1                     (OPENAI_API_KEY из shared.env, с балансом)
#   anthropic  → claude-opus-4-8 (нативно)   (ANTHROPIC_API_KEY из cyprus.env — сейчас $0, пополнить)
AI_PROVIDER=openrouter

OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...

# Сменить модель внутри провайдера (опц.):
# AI_MODEL=anthropic/claude-opus-4.8   # или openai/gpt-4o, anthropic/claude-sonnet-4.6 ...

# APP_TOKEN — занавес от случайных (виден в клиенте). Для 1 пользователя можно пусто.
APP_TOKEN=
ALLOW_ORIGINS=https://sizur.xyz,http://localhost:5173,http://localhost:4173
PORT=8787
