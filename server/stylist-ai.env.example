# Скопируй в stylist-ai.env и заполни. На Hetzner OPENROUTER_API_KEY есть в server1/cyprus.env.
# По умолчанию: OpenRouter → claude-opus-4.8 (та же модель Claude, биллинг OpenRouter).
OPENROUTER_API_KEY=sk-or-...
# Опционально сменить модель/провайдера:
# AI_MODEL=anthropic/claude-opus-4.8   (или anthropic/claude-sonnet-4.6 — дешевле)
# AI_BASE_URL=https://openrouter.ai/api/v1
# APP_TOKEN — занавес от случайных (виден в клиенте). Для 1 пользователя можно пусто.
APP_TOKEN=
ALLOW_ORIGINS=https://sizur.xyz,http://localhost:5173,http://localhost:4173
PORT=8787
