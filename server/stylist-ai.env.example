# Скопируй в stylist-ai.env. Выбери провайдера и впиши его ключ.
#
# AI_PROVIDER = openai | anthropic | openrouter
#   openai     → gpt-4.1            (OPENAI_API_KEY; ключ в shared.env уже с балансом ✓)
#   anthropic  → claude-opus-4-8    (ANTHROPIC_API_KEY; в cyprus.env сейчас $0 — пополнить)
#   openrouter → anthropic/claude-opus-4.8 (OPENROUTER_API_KEY в cyprus.env, с балансом)
AI_PROVIDER=openai

OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# Сменить модель в рамках провайдера (опц.):
# AI_MODEL=gpt-4.1            # или claude-opus-4-8 / anthropic/claude-opus-4.8 / claude-sonnet-4-6

# APP_TOKEN — занавес от случайных (виден в клиенте). Для 1 пользователя можно пусто.
APP_TOKEN=
ALLOW_ORIGINS=https://sizur.xyz,http://localhost:5173,http://localhost:4173
PORT=8787
