# Скопируй в stylist-ai.env и заполни. На Hetzner ANTHROPIC_API_KEY можно взять из server1/cyprus.env.
ANTHROPIC_API_KEY=sk-ant-...
# Общий токен, который шлёт PWA (занавес от случайных, не настоящая защита — он виден в клиенте).
APP_TOKEN=
# Через запятую. Прод-origin приложения + локалка.
ALLOW_ORIGINS=https://sizur.xyz,http://localhost:5173,http://localhost:4173
PORT=8787
